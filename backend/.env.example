# Server
PORT=3000
NODE_ENV=production

# PostgreSQL
DATABASE_URL=postgresql://cloader:CHANGE_ME@127.0.0.1:5432/cloader

# JWT (RS256) — paths to PEM files on the server
JWT_PRIVATE_KEY_PATH=/etc/cloader/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/etc/cloader/jwt_public.pem
JWT_ACCESS_EXPIRES_IN=15m

# Argon2id pepper (random 32+ byte hex string)
ARGON2_PEPPER=CHANGE_ME_TO_RANDOM_64_CHAR_HEX

# TOTP secret encryption key (32-byte hex for AES-256)
TOTP_ENCRYPTION_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://yourdomain.com

# Rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
