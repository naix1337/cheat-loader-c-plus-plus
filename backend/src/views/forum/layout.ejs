<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof forumTitle !== 'undefined' ? forumTitle : 'Forum' %> — insolution.cloud</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0a0a0f;
      color: #e0e0e0;
      min-height: 100vh;
    }
    a { color: #00d4ff; text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Nav */
    .nav {
      background: #12121a;
      border-bottom: 1px solid #1e1e2a;
      padding: 0 24px;
    }
    .nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }
    .nav-brand {
      font-size: 18px;
      font-weight: 700;
      color: #00d4ff;
      letter-spacing: -0.3px;
    }
    .nav-brand:hover { text-decoration: none; }
    .nav-links { display: flex; align-items: center; gap: 24px; }
    .nav-links a {
      font-size: 14px;
      color: #aaa;
      font-weight: 500;
      transition: color 0.15s;
    }
    .nav-links a:hover { color: #00d4ff; text-decoration: none; }
    .nav-links a.active { color: #00d4ff; }
    .nav-user {
      font-size: 13px;
      color: #888;
    }
    .nav-user span { color: #e0e0e0; font-weight: 500; }
    .nav-user a {
      font-size: 13px;
      margin-left: 12px;
      color: #ff5555;
      font-weight: 500;
    }
    .nav-user a:hover { color: #ff7777; }

    /* Main wrapper */
    .wrapper {
      max-width: 1100px;
      margin: 0 auto;
      padding: 32px 24px;
    }

    /* Page header */
    .page-header {
      margin-bottom: 28px;
    }
    .page-header h1 {
      font-size: 26px;
      font-weight: 700;
      color: #f0f0f0;
    }
    .page-header p {
      color: #888;
      font-size: 14px;
      margin-top: 4px;
    }

    /* Breadcrumb */
    .breadcrumb {
      font-size: 13px;
      color: #666;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .breadcrumb a { color: #888; }
    .breadcrumb a:hover { color: #00d4ff; }
    .breadcrumb .sep { color: #444; }
    .breadcrumb .current { color: #aaa; }

    /* Cards */
    .card {
      background: #12121a;
      border: 1px solid #1e1e2a;
      border-radius: 12px;
      overflow: hidden;
    }

    /* Card table-like rows */
    .row-list { list-style: none; }
    .row-item {
      display: flex;
      align-items: center;
      padding: 16px 20px;
      border-bottom: 1px solid #1e1e2a;
      gap: 16px;
      transition: background 0.1s;
    }
    .row-item:last-child { border-bottom: none; }
    .row-item:hover { background: rgba(255,255,255,0.02); }
    .row-item.pinned {
      background: rgba(0,212,255,0.04);
      border-left: 3px solid #00d4ff;
    }
    .row-main { flex: 1; min-width: 0; }
    .row-title {
      font-size: 15px;
      font-weight: 600;
      color: #e0e0e0;
      margin-bottom: 2px;
    }
    .row-title a { color: #e0e0e0; }
    .row-title a:hover { color: #00d4ff; text-decoration: none; }
    .row-meta {
      font-size: 12px;
      color: #666;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .row-stats {
      text-align: right;
      flex-shrink: 0;
      min-width: 100px;
    }
    .row-stats .num {
      display: block;
      font-size: 14px;
      font-weight: 600;
      color: #e0e0e0;
    }
    .row-stats .label {
      font-size: 11px;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .row-last {
      flex-shrink: 0;
      min-width: 160px;
      text-align: right;
      font-size: 12px;
      color: #888;
    }
    .row-last .author { color: #aaa; }
    .row-last .date { color: #666; font-size: 11px; }

    /* Badges */
    .badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 2px 8px;
      border-radius: 4px;
      margin-left: 8px;
    }
    .badge-pin {
      background: rgba(0,212,255,0.15);
      color: #00d4ff;
    }
    .badge-lock {
      background: rgba(255,85,85,0.15);
      color: #ff5555;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 20px;
      background: #00d4ff;
      color: #0a0a0f;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      text-decoration: none;
    }
    .btn:hover { background: #00bde6; text-decoration: none; }
    .btn:active { transform: scale(0.97); }
    .btn-sm { padding: 6px 14px; font-size: 13px; }
    .btn-outline {
      background: transparent;
      border: 1px solid #2a2a3a;
      color: #aaa;
    }
    .btn-outline:hover { border-color: #00d4ff; color: #00d4ff; background: rgba(0,212,255,0.05); }
    .btn-danger { background: #ff4444; color: #fff; }
    .btn-danger:hover { background: #cc3333; }
    .btn-danger-outline {
      background: transparent;
      border: 1px solid #ff4444;
      color: #ff5555;
    }
    .btn-danger-outline:hover { background: rgba(255,68,68,0.1); }

    /* Form elements */
    .form-group { margin-bottom: 20px; }
    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: #aaa;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .form-control {
      width: 100%;
      padding: 12px 14px;
      background: #0a0a0f;
      border: 1px solid #2a2a3a;
      border-radius: 8px;
      color: #e0e0e0;
      font-size: 15px;
      font-family: inherit;
      transition: border-color 0.2s;
      outline: none;
    }
    .form-control:focus {
      border-color: #00d4ff;
      box-shadow: 0 0 0 3px rgba(0,212,255,0.1);
    }
    textarea.form-control {
      min-height: 180px;
      resize: vertical;
      line-height: 1.6;
    }

    /* Pagination */
    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 24px;
      padding: 16px 0;
    }
    .pagination a, .pagination span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 36px;
      height: 36px;
      padding: 0 10px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      background: #12121a;
      border: 1px solid #1e1e2a;
      color: #aaa;
      transition: all 0.15s;
      text-decoration: none;
    }
    .pagination a:hover {
      border-color: #00d4ff;
      color: #00d4ff;
    }
    .pagination .active {
      background: #00d4ff;
      color: #0a0a0f;
      border-color: #00d4ff;
      font-weight: 700;
    }
    .pagination .disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .pagination .info {
      background: transparent;
      border: none;
      color: #666;
      font-size: 13px;
    }

    /* Posts */
    .post {
      display: flex;
      gap: 20px;
      padding: 20px;
      border-bottom: 1px solid #1e1e2a;
    }
    .post:last-child { border-bottom: none; }
    .post-sidebar {
      flex-shrink: 0;
      width: 140px;
      text-align: center;
    }
    .post-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: #1e1e2a;
      color: #00d4ff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      font-weight: 700;
      margin: 0 auto 8px;
      border: 2px solid #2a2a3a;
    }
    .post-author {
      font-size: 14px;
      font-weight: 600;
      color: #e0e0e0;
    }
    .post-date {
      font-size: 11px;
      color: #555;
      margin-top: 2px;
    }
    .post-content {
      flex: 1;
      min-width: 0;
      line-height: 1.7;
      font-size: 14px;
      color: #d0d0d0;
    }
    .post-content p { margin-bottom: 12px; }
    .post-content p:last-child { margin-bottom: 0; }
    .post-actions {
      margin-top: 12px;
      display: flex;
      gap: 8px;
    }
    .post-actions a {
      font-size: 12px;
      color: #888;
      font-weight: 500;
    }
    .post-actions a:hover { color: #00d4ff; }
    .post-actions a.delete-link { color: #ff5555; }
    .post-actions a.delete-link:hover { color: #ff7777; }

    /* Messages / alerts */
    .alert {
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 20px;
    }
    .alert-info {
      background: rgba(0,212,255,0.08);
      border: 1px solid rgba(0,212,255,0.2);
      color: #66e0ff;
    }
    .alert-warning {
      background: rgba(255,170,0,0.08);
      border: 1px solid rgba(255,170,0,0.2);
      color: #ffcc44;
    }
    .alert-error {
      background: rgba(255,68,68,0.08);
      border: 1px solid rgba(255,68,68,0.2);
      color: #ff6666;
    }

    /* Action bar */
    .action-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
      gap: 12px;
      flex-wrap: wrap;
    }
    .action-bar .left { display: flex; align-items: center; gap: 12px; }

    /* Locked thread banner */
    .locked-banner {
      text-align: center;
      padding: 24px;
      color: #888;
      font-size: 14px;
    }
    .locked-banner .icon {
      font-size: 32px;
      display: block;
      margin-bottom: 8px;
    }

    /* Category card on index */
    .cat-card {
      display: block;
      padding: 20px;
      border-bottom: 1px solid #1e1e2a;
      transition: background 0.1s;
    }
    .cat-card:last-child { border-bottom: none; }
    .cat-card:hover { background: rgba(255,255,255,0.02); text-decoration: none; }
    .cat-name {
      font-size: 16px;
      font-weight: 600;
      color: #e0e0e0;
      margin-bottom: 4px;
    }
    .cat-card:hover .cat-name { color: #00d4ff; }
    .cat-desc {
      font-size: 13px;
      color: #888;
      margin-bottom: 8px;
    }
    .cat-stats {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 12px;
      color: #666;
    }
    .cat-stats span { display: flex; align-items: center; gap: 4px; }
    .cat-stats .num { color: #aaa; font-weight: 600; }
    .cat-last {
      margin-top: 8px;
      font-size: 12px;
      color: #555;
    }
    .cat-last a { color: #888; }
    .cat-last a:hover { color: #00d4ff; }

    /* Responsive */
    @media (max-width: 768px) {
      .nav-inner { flex-wrap: wrap; height: auto; padding: 12px 0; gap: 8px; }
      .nav-links { gap: 16px; }
      .wrapper { padding: 20px 16px; }
      .row-item { flex-wrap: wrap; padding: 12px 16px; }
      .row-stats { min-width: auto; }
      .row-last { min-width: auto; text-align: left; width: 100%; padding-left: 0; margin-top: 4px; }
      .post { flex-direction: column; gap: 12px; }
      .post-sidebar { width: 100%; display: flex; align-items: center; gap: 12px; }
      .post-avatar { margin: 0; }
      .action-bar { flex-direction: column; align-items: stretch; }
      .page-header h1 { font-size: 22px; }
    }
    @media (max-width: 480px) {
      .nav { padding: 0 16px; }
      .nav-links { gap: 12px; }
      .cat-stats { flex-wrap: wrap; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">insolution.cloud</a>
      <div class="nav-links">
        <a href="/forum" class="<%= (typeof activeNav !== 'undefined' && activeNav === 'forum') ? 'active' : '' %>">Forum</a>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <div class="nav-user">
            <span><%= currentUser.username %></span>
            <a href="/logout">Logout</a>
          </div>
        <% } else { %>
          <a href="/login">Login</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="wrapper">
    <%- body %>
  </main>
</body>
</html>
